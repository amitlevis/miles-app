# Supabase (REQUIRED). Find these at:
#   https://supabase.com/dashboard/project/<project>/settings/api
# These are public keys — safe to expose in client code — but we still
# load them from .env so the project repo can be safely shared/forked.
EXPO_PUBLIC_SUPABASE_URL=https://zowwuzepcttifosnjxki.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# RevenueCat (OPTIONAL — only needed for in-app purchases).
# Find these at: https://app.revenuecat.com → Project settings → API Keys.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Sentry (OPTIONAL — for crash reporting in production builds).
EXPO_PUBLIC_SENTRY_DSN=
